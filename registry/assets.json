  "install_surfaces": [
    {
      "id": "cursor",
      "paths": [".cursor/rules/", "hooks/hooks.json", "mcp/"],
      "bootstrap_flag": "--target cursor"
    },
    {
      "id": "claude",
      "paths": [".claude/commands/", "CLAUDE.md", "skills/"],
      "bootstrap_flag": "--target claude"
    },
    {
      "id": "vscode",
      "paths": ["vscode-extension/", ".github/copilot-instructions.md"],
