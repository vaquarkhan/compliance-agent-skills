    },
    {
      "id": "jetbrains",
      "paths": ["jetbrains-plugin/"],
      "bootstrap_flag": "--target jetbrains"
    },
    {
      "id": "python-agent",
      "paths": ["agent.py", "redaction.py", "skills/", "requirements.txt"],
      "bootstrap_flag": "--target python"
    }
